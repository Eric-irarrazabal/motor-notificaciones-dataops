# Plantilla de variables de entorno. Copiar a .env y reemplazar valores.


# Clave Fernet para cifrar identificadores de usuario.
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=ingresalaclavegeneradaporfernet

# Cadena de conexion a Supabase (PostgreSQL).
# Obtenerla desde: Supabase Dashboard -> Project Settings -> Database -> Connection pooler.
# Modo: Session. Reemplazar [YOUR-PASSWORD] por la contrasena del proyecto.
DATABASE_URL=postgresql://postgres.xxxxx:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
